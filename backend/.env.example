# Database
DATABASE_URL=postgresql+asyncpg://smc_user:smc_password@localhost:5432/smc_dashboard

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# Scan
SCAN_INTERVAL_SECONDS=60
WATCHLIST=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT

# SMC Parameters
MIN_SCORE_TO_EMIT=40
MAX_OB_TOUCHES=3
OB_SL_BUFFER_ATR=0.3

# Trading Economics API (optional — untuk live economic calendar)
# Daftar gratis di: https://tradingeconomics.com/api/
TE_API_KEY=

# Binance Demo API (untuk live positions + wallet di dashboard)
# Sama dengan API key yang dipakai di bot Telegram
# Daftar di: https://testnet.binancefuture.com
BINANCE_DEMO_API_KEY=
BINANCE_DEMO_API_SECRET=
